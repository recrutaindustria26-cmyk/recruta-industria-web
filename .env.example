# ===== Banco de dados (Supabase / PostgreSQL) =====
# Connection string COM pgBouncer (pooler) - usada pela aplicação em runtime.
# No painel do Supabase: Project Settings > Database > Connection string > "Transaction" (porta 6543).
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Connection string DIRETA (porta 5432) - usada pelo Prisma para migrations.
# No painel do Supabase: connection string "Session" (porta 5432) ou "Direct connection".
DIRECT_URL="postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:5432/postgres"

# ===== NextAuth =====
# URL pública da aplicação (sem barra final). Ex.: http://localhost:3000 em dev.
NEXTAUTH_URL="http://localhost:3000"
# Segredo do NextAuth. Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ===== Login com Google (Google Cloud Console > OAuth 2.0) =====
# Authorized redirect URI deve ser: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Mesmo Client ID exposto ao client (controla a exibição do botão Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
